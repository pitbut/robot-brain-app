<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_vertical">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Робот — телефон-мозг"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"/>

    <!-- Нужна ARCore для обработки глубины (объезд препятствий) — сама
         картинка тут не отображается, реальное видео уходит оператору
         на карту, здесь просто должен быть активный GL-контекст. -->
    <android.opengl.GLSurfaceView
        android:id="@+id/arSurfaceView"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_marginBottom="16dp"/>

    <EditText
        android:id="@+id/hostInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="домен сервера, напр. robot-platform-xxxx.onrender.com"
        android:inputType="textUri"/>

    <Button
        android:id="@+id/startButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Начать трансляцию"/>

    <Button
        android:id="@+id/stopButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:backgroundTint="#D9403F"
        android:text="Остановить"/>

    <TextView
        android:id="@+id/statusText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Остановлено"
        android:textSize="14sp"/>

</LinearLayout>
